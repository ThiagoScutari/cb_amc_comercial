# Template de variáveis de ambiente — copie para .env e preencha.
# NUNCA commitar o .env real (está no .gitignore).

# --- Claude ---
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-6
ROUTER_MODEL=claude-haiku-4-5-20251001

# --- STT / TTS ---
OPENAI_API_KEY=                 # Whisper (STT)
ELEVENLABS_API_KEY=             # TTS (voz natural PT-BR) — segredo, nunca commitar
ELEVENLABS_VOICE_ID=            # voz PT-BR escolhida (Creator)
ELEVENLABS_MODEL=eleven_flash_v2_5        # latência baixa; eleven_multilingual_v2 = + natural
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128    # MP3 enviado como type:audio (Cloud API não transcodifica)

# --- Captura do catálogo Colcci (scraping) ---
# Usado SOMENTE por scripts/ (captura -> app/data/colcci_products.json).
# NUNCA é lido pelo app/ nem pelos testes (eles leem o fixture).
FIRECRAWL_API_KEY=              # scraping da vitrine Colcci (API VTEX pública não expõe o catálogo)

# --- WhatsApp (Cloud API / Meta) ---
WHATSAPP_WABA_ID=1012220618436445
WHATSAPP_PHONE_NUMBER_ID=1194241667106693
WHATSAPP_NUMERO_VIRTUAL=+1 555-957-6970   # informativo; não usado em chamadas
WHATSAPP_ACCESS_TOKEN=__PREENCHER__       # token permanente via System User (whatsapp_business_messaging + _management)
WHATSAPP_VERIFY_TOKEN=__DEFINIR__         # string aleatória que VOCÊ inventa; usada na verificação do webhook
WHATSAPP_APP_SECRET=__PREENCHER__         # app secret do app (developers.facebook.com) p/ validar assinatura do webhook
WHATSAPP_API_VERSION=v23.0                # versão do Graph API

# --- WhatsApp (Evolution) — DEPRECADO: migrado para Cloud API, manter para rollback ---
EVOLUTION_API_URL=              # http://cb_amc_comercial_evolution:8080 (interno) ou domínio
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=cb-amc-comercial

# --- Postgres (usado pelo docker-compose para criar o banco) ---
POSTGRES_USER=cb_amc
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=cb_amc_comercial

# --- Banco (host = nome do container, NÃO localhost — ver §13.1) ---
# Deve casar com POSTGRES_USER/PASSWORD/DB acima.
DATABASE_URL=postgresql+psycopg://cb_amc:troque-esta-senha@cb_amc_comercial_db:5432/cb_amc_comercial

# --- App ---
APP_PORT=8005                   # porta de host reservada (PORT-REGISTRY)
DATA_DIR=data
LOG_LEVEL=INFO
